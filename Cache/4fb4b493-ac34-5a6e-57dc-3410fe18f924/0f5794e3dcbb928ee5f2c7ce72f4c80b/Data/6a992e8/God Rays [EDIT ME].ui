{ 
	"ui": 
	[
		{
        	"label": "Graph Parameters",
        	"widget": "group_start"
        },
{
                	"label":       "Blend Mode",
                	"bindingType": "defineSelect",
                	"values":      
                	[
                		
                		{
                			"value": "NODE_44_DROPLIST_ITEM 0",
                			"label": "Add"
                		},
                		
                		{
                			"value": "NODE_44_DROPLIST_ITEM 1",
                			"label": "Screen"
                		},
                		
                		{
                			"value": "NODE_44_DROPLIST_ITEM 2",
                			"label": "Average"
                		}
                	],
                	"sortIndex":   "0",
                	"hint":        ""
                },
                
                {
                	"bindingName": "samples",
                	"label":       "Samples",
                	"widget":      "slider",
                	"min":         10,
                	"max":         100,
                	"step":        "1",
                	"sortIndex":   "0",
                	"hint":        "",
                	"default":     "1.0"
                },
                
                {
                	"bindingName": "cutOff",
                	"label":       "Cut Off",
                	"widget":      "slider",
                	"min":         0.25,
                	"max":         1,
                	"step":        "0.01",
                	"sortIndex":   "0",
                	"hint":        "",
                	"default":     "1.0"
                },
                
                {
                	"bindingName": "cutOffFrame",
                	"label":       "CutOff Frame",
                	"widget":      "slider",
