          - mLabel: Specular AO
            mType: Define
            mName: ENABLE_SPECULAR_AO
            mWidget: group_start
            mHint: |-
              Define: ENABLE_SPECULAR_AO
              
              Allow AO to influence indirect specular lighting (reflections).
            mMin: ~
            mMax: ~
            mStep: ~
            mDefaultVal: ~
            mValues:
              []
          - mLabel: Intensity
            mType: Property
            mName: specularAoIntensity
            mWidget: slider
            mHint: |-
              Property: specularAoIntensity
              
              Specifies the amount of influence AO has on reflections. 
              For metals the specular AO at its darkest approaches a saturated/darkened version of the metal color (ex: dark gold for gold). 
              For non-metals, this is essentially the same as 'Darkeing'.
            mMin: 0.000000
            mMax: 1.000000
            mStep: 0.010000
            mDefaultVal: 1.000000
            mValues:
              []
          - mLabel: Darkening
            mType: Property
            mName: specularAoDarkening
            mWidget: slider
            mHint: |-
              Property: specularAoDarkening
              
              For metals, this shifts the darkest AO color from a saturated version of the metal color towards pure black. 
              For non-metals it's essentially equivalent to 'Intensity'.
            mMin: 0.000000
            mMax: 1.000000
            mStep: 0.010000
            mDefaultVal: 1.000000
            mValues:
              []
          - mLabel: ""
            mType: GroupEnd
