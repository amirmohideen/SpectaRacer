            mType: Property
            mName: roughness
            mWidget: slider
            mHint: |-
              Property: roughness
              
              1 means completely rough (diffuse), 0 means perfectly smooth and shiny. 
              Multiplies the roughness channel of the Material Params texture if enabled. 
              If your roughness is 1 and your metallic is 0, it's more efficient to disable Specular alltogether.
            mMin: 0.000000
            mMax: 1.000000
            mStep: 0.010000
            mDefaultVal: 1.000000
            mValues:
              []
          - mLabel: Texture
            mType: Property
            mName: materialParamsTex
            mWidget: texture_group
            mHint: |-
              Property: materialParamsTex
              
              Material params texture should have: R - metalness, G - roughness, B - ambient occlusion.
            mMin: ~
            mMax: ~
            mStep: ~
            mDefaultVal: ~
            mValues:
              []
