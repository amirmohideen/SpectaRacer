  SetupScript:
    code: ""
  Description: |+
    Roulette
    Provides a roulette UI around the Snap Button. Requires a Camera.
    
    API:
    * addCallbackOnSelection(cb funtion): void 
       Adds a callback that is called when the button is selected.
    
    * popCallbackOnSelection(): void
       Removes the last added onSelection callback.
    
    * moveToButton(idx: int): void
      Smoothly moves the roulette to the button with the number idx.
    
    * selectButton(idx: int): void
       Selects and centers the button with the number idx.
    
    * getSelectedButton(): int
       Returns index of the selected button.
    
    
