            mWidget: slider
            mHint: "Property: reflectionIntensity"
            mMin: 0.000000
            mMax: 10.000000
            mStep: 0.010000
            mDefaultVal: 1.000000
            mValues:
              []
          - mLabel: Modulation Map
            mType: Define
            mName: Tweak_N177
            mWidget: group_start
            mHint: |-
              Define: Tweak_N177
              
              This texture modulates the reflection color. It can be RGB or greyscale.
            mMin: ~
            mMax: ~
            mStep: ~
            mDefaultVal: ~
            mValues:
              []
